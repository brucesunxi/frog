DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
GOOGLE_CLIENT_IDS=your-web-client-id.apps.googleusercontent.com,your-android-client-id.apps.googleusercontent.com
JWT_SECRET=replace-with-a-long-random-secret
GOOGLE_PLAY_PACKAGE_NAME=com.frogfrenzy.game
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON_BASE64=base64-encoded-play-console-service-account-json
ANDROID_KEYSTORE_PATH=/absolute/path/to/release.keystore
ANDROID_KEYSTORE_PASSWORD=replace-me
ANDROID_KEY_ALIAS=release
ANDROID_KEY_PASSWORD=replace-me
PORT=3000
